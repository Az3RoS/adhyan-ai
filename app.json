{
  "expo": {
    "name": "Adhyan",
    "slug": "adhyan",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "adhyan",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f6f1e8",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f6f1e8"
      },
      "package": "com.adhyan.app",
      "versionCode": 1,
      "minSdkVersion": 26,
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "4283bbb7-3f28-4713-9131-da8461240071"
      }
    }
  }
}
